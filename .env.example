# Public-safe local defaults. Copy to .env and adjust locally.

AGENTGATEWAY_IMAGE=cr.agentgateway.dev/agentgateway:v1.3.1
AGENTGATEWAY_HTTP_PORT=3000
AGENTGATEWAY_ADMIN_PORT=15000
AGENTGATEWAY_STATS_PORT=15020

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST_BASE_URL=http://localhost:11434
OLLAMA_LAPTOP_MODEL=llama3.2:3b
OLLAMA_LAPTOP_SECONDARY_MODEL=qwen2.5:7b
OLLAMA_PRIMARY_MODEL=qwen3.6:35b
OLLAMA_SECONDARY_MODEL=gpt-oss:120b
OLLAMA_MAX_REASONING_MODEL=deepseek-r1:671b-0528-q4_K_M
PUBLIC_MODEL_ALIAS=enterprise-reasoning-latest
LAPTOP_MODEL_ALIAS=laptop-demo
AGENTGATEWAY_READER_KEY=sk-demo-reader-local
AGENTGATEWAY_OPERATOR_KEY=sk-demo-operator-local

KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6.3
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=agentgateway
KEYCLOAK_CLIENT_ID=agentgateway-demo
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.154.0
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
GRAFANA_IMAGE=grafana/grafana:13.0.2
JAEGER_IMAGE=jaegertracing/jaeger:2.8.0
