{
  "realm": "agentgateway",
  "enabled": true,
  "displayName": "agentgateway demo",
  "clients": [
    {
      "clientId": "agentgateway-demo",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:*/*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentgateway-demo",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "reader" },
      { "name": "operator" }
    ]
  },
  "users": [
    {
      "username": "alice-reader",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Reader",
      "email": "alice-reader@example.local",
      "requiredActions": [],
      "attributes": {
        "tenant": ["tenant-a"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "reader-password",
          "temporary": false
        }
      ],
      "realmRoles": ["reader"]
    },
    {
      "username": "oliver-operator",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Oliver",
      "lastName": "Operator",
      "email": "oliver-operator@example.local",
      "requiredActions": [],
      "attributes": {
        "tenant": ["tenant-b"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "operator-password",
          "temporary": false
        }
      ],
      "realmRoles": ["operator"]
    }
  ]
}
